*.Rproj
.Renviron
renv/library/
renv/staging/
renv/python/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/

# --- Temporary ---
*.tmp
*.bak
*~
logs/